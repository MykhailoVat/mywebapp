#!/bin/bash

cd "/opt/mywebapp" || exit 1

case "$1" in
  start)
    docker compose up -d
    ;;
  stop)
    docker compose down
    ;;
  restart)
    docker compose restart
    ;;
  status)
    docker compose ps
    ;;
  logs)
    docker compose logs -f
    ;;
  reload-nginx)
    docker compose restart nginx
    ;;
  *)
    echo "Usage: $0 {start|stop|restart|status|logs|reload-nginx}"
    exit 1
esac